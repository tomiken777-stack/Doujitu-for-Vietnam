            }.padding(.horizontal)
            Button("Khôi phục giao dịch mua") { Task { await subStore.restore() } }.foregroundColor(.secondary)
            VStack(spacing: 15) {
                Link("Điều khoản sử dụng (EULA)", destination: URL(string: "https://www.apple.com/legal/internet-services/itunes/dev/stdeula/")!)
                Link("Chính sách bảo mật", destination: URL(string: "https://trapezoidal-partridge-6ad.notion.site/Doujitu-2b0ab0596b9880d68f09e3757b41f160?pvs=143")!)
            }
            .font(.caption)
            .padding(.top, 20)
        }
    }
}

class AppDelegate: NSObject, UIApplicationDelegate {
